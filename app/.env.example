# Linear Integration
# Get your API key from: https://linear.app/settings/api
LINEAR_API_KEY=your_linear_api_key_here

# Linear Team ID
# Find your team ID in Linear: Settings > Teams, or use the GraphQL explorer
LINEAR_TEAM_ID=your_team_id_here

# Discord OAuth Configuration
# Get these from: https://discord.com/developers/applications
DISCORD_CLIENT_ID=your_discord_client_id_here
DISCORD_CLIENT_SECRET=your_discord_client_secret_here

# Discord Guild Configuration
DISCORD_GUILD_ID=your_guild_id_here

# Discord Role IDs (for access control)
# Comma-separated list of role IDs that have staff access
DISCORD_STAFF_ROLE_IDS=role_id_1,role_id_2,role_id_3
NEXT_PUBLIC_DISCORD_STAFF_ROLE_IDS=role_id_1,role_id_2,role_id_3

# Discord role ID for board access
DISCORD_BOARD_ROLE_ID=your_board_role_id_here

# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_nextauth_secret_here

# Debug Mode (Optional)
NEXT_PUBLIC_DEBUG_MODE=false
